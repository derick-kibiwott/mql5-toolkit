{
  "C_Cpp.default.includePath": [
    "${workspaceFolder}/**",
    "${workspaceFolder}/../../Include/**"
  ],
  "files.associations": {
    "*.mq5": "cpp",
    "*.mqh": "cpp",
    "*.mq4": "cpp"
  },
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/*.ex5": true
  },
  "editor.quickSuggestions": {
    "comments": "on",
    "strings": "on",
    "other": "on"
  },
  "C_Cpp.errorSquiggles": "disabled"
}
